# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
dird
artifacts
*.local

# Local LLM weights (downloaded on-demand to <app_data>/llm/, also for repo safety)
*.gguf

# Reportes de muestra pesados (no versionar; regenerables desde la app)
docs/sample-report-*.pdf

# Encrypted `.dird` exports — sensitive clinical data, never commit
*.dird

# SQLite/SQLCipher local databases
*.db
*.db-journal
*.db-wal
*.db-shm

# Environment variables (solo archivos locales personales)
.env.local
.env.development.local
.env.production.local

# Backend data (generado dinámicamente)
backend/tokens.json

# Claude Code local state
.claude/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
backend/data/api_keys.json

