# DIRD Environment Variables
# Copy this file to .env.development or .env.production and configure

# ============================================
# 🎯 CONFIGURACIÓN DE DEPLOY
# ============================================
# Para cambiar dónde se despliega la app (/academia/, /dird/, etc.):
# Edita vite.config.ts línea 14: DEPLOY_BASE_URL
# NO uses variables de entorno para esto
# ============================================

# ===== DEVELOPMENT (.env.development) =====
# Apunta al servidor remoto para desarrollo/testing
VITE_API_BASE_URL=https://tmeduca.org/dird/backend

# ===== PRODUCTION (.env.production) =====
# Usa ruta relativa (BASE/backend) porque el build ya estará en el servidor
VITE_API_USE_RELATIVE=true
