{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DIRD+",
  "version": "1.0.0",
  "identifier": "org.tmeduca.dird",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev:tauri",
    "beforeBuildCommand": "pnpm build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "DIRD+",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' blob: data: tauri: http://ipc.localhost",
        "script-src": "'self' 'wasm-unsafe-eval' https://cdn.jsdelivr.net",
        "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com",
        "font-src": "'self' data: https://fonts.gstatic.com",
        "img-src": "'self' data: blob: https:",
        "media-src": "'self' blob: data:",
        "worker-src": "'self' blob:",
        "connect-src": "'self' ipc: http://ipc.localhost https://cdn.jsdelivr.net https://tmeduca.org https://*.tmeduca.org https://api.github.com https://raw.githubusercontent.com https://objects.githubusercontent.com https://github.com"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
